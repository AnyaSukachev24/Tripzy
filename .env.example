# =============================================================
# Tripzy .env.example — copy to .env and fill in real values
# NEVER commit your actual .env to git
# =============================================================

# --- PRIMARY LLM (LLMOD / OpenAI-compatible) ---
LLMOD_API_KEY=your_llmod_api_key_here
LLMOD_BASE_URL=https://api.llmod.ai/v1
LLM_MODEL=RPRTHPB-gpt-5-mini

# --- GOOGLE GEMINI (Alternative LLM) ---
GOOGLE_API_KEY=your_google_api_key_here

# --- OBSERVABILITY (LangSmith — Optional) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=tripzy-agent

# --- DATA LAYER (Supabase — User Profiles) ---
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# --- RAG: DESTINATIONS (Pinecone — Wikivoyage index) ---
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=tripzy
PINECONE_INDEX_HOST=https://your-dest-index-host.svc.pinecone.io

# --- RAG: ATTRACTIONS (Pinecone — separate attractions index) ---
PINECONE_API_KEY_ATTRACTIONS=your_pinecone_attractions_key
PINECONE_INDEX_NAME_ATTRACTIONS=tripzy
PINECONE_INDEX_HOST_ATTRACTIONS=https://your-attractions-index-host.svc.pinecone.io

# --- FLIGHT & HOTEL SEARCH (Amadeus) ---
# Free sandbox: https://developers.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
# Set to "true" to use Amadeus production (real bookings/prices), default is sandbox
AMADEUS_PRODUCTION=false

# --- FLIGHT SEARCH (Kiwi.com / Tequila API — Optional) ---
# Free tier: https://tequila.kiwi.com/portal/login
KIWI_API_KEY=your_kiwi_api_key

# --- HOTEL SEARCH (SerpAPI — Optional) ---
# https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# --- CORS (Production) ---
# Comma-separated allowed origins. Set your real domain in production.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- TEST / EVALUATION (Groq — Optional, free tier) ---
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=qwen/qwen3-32b
